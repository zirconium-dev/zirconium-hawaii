build-depends:
- freedesktop-sdk.bst:components/bpf.bst
- freedesktop-sdk.bst:components/findutils.bst
- freedesktop-sdk.bst:components/gcc.bst
- freedesktop-sdk.bst:components/libseccomp.bst
- freedesktop-sdk.bst:components/python3.bst
- freedesktop-sdk.bst:components/rust.bst
- freedesktop-sdk.bst:components/stripper.bst
- freedesktop-sdk.bst:components/systemd.bst

depends:
- freedesktop-sdk.bst:public-stacks/runtime-minimal.bst
- freedesktop-sdk.bst:components/polkit.bst

config:
  build-commands:
  - cargo build --release --all-features --frozen --offline --workspace

  install-commands:
  - |
    find target/release \
      -maxdepth 1 -type f -executable ! -name '*.so' ! -name 'xtask' \
      -exec install -Dm0755 -t "%{install-root}%{bindir}" {} +
    ./target/release/xtask install --destdir "%{install-root}"
  - |
    %{install-extra}
